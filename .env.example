# Notion
NOTION_API_TOKEN=

# Stage 8 workflow target (Notion page ID where workflow outputs are created)
NOTION_WORKFLOW_PARENT_ID=

# Google Drive service account JSON
GOOGLE_DRIVE_CREDENTIALS_PATH=
GOOGLE_DRIVE_CREDENTIALS_JSON=

# Gmail OAuth client credentials JSON (Desktop app)
GMAIL_CREDENTIALS_PATH=
GMAIL_CREDENTIALS_JSON=

# Legacy shared Google credentials path (backward-compatible fallback)
GOOGLE_CREDENTIALS_PATH=
GOOGLE_CREDENTIALS_JSON=

# AI agents (Gemini is primary)
AGENT_PROVIDER=gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# Gmail OAuth2 token cache (auto-created on first login, never commit)
GMAIL_TOKEN_PATH=.gmail_token.json

# Feature flags
# Set to false to disable Gmail integration without removing credentials (default: true)
GMAIL_ENABLED=true

# Scheduler / reminders
REMINDER_STORE_PATH=data/reminders.json
SCHEDULER_POLL_SECONDS=30

# Optional daily proactive Gmail digest (logged by scheduler)
DAILY_GMAIL_DIGEST_ENABLED=false
DAILY_GMAIL_DIGEST_HOUR=8
DAILY_GMAIL_DIGEST_MINUTE=0

# Optional weekly Stage 9 library maintenance reminder (logged by scheduler)
LIBRARY_MAINTENANCE_ENABLED=false
LIBRARY_MAINTENANCE_DAY=sun
LIBRARY_MAINTENANCE_HOUR=9
LIBRARY_MAINTENANCE_MINUTE=0

# GitHub (cross-repo orchestration)
# Fine-grained PAT with repo (read), issues (write), actions (write)
GITHUB_PAT=
